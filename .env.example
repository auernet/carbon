# Carbon production environment template.
# Copy to .env or paste into Coolify "Environment variables" UI.

NODE_ENV=production
PORT=4040
BIND_HOST=0.0.0.0

# Production admin login — set these so the live password is NEVER committed to the repo.
# Re-applied (idempotently) on every boot; takes precedence over data/.carbon-admin.json.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# Optional SMTP (reminders, dunning, password-reset emails).
# Leave blank to disable outgoing email.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Backup retention (default 30 nightly archives).
CARBON_BACKUP_RETENTION=30

# Off-site backup copy — runs after each nightly backup with {file} = the archive path.
# STRONGLY recommended: backups otherwise live only on the same disk as the live DB.
# Example: rclone copy {file} myremote:carbon-backups   (the tool must be in the image)
CARBON_BACKUP_POSTHOOK=
